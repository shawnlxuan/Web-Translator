{
  "name": "ai-translator-extension",
  "version": "1.0.0",
  "description": "AI-powered immersive webpage translation browser extension",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vite build --config vite.content.config.ts && node scripts/copy-manifest.mjs && cp -r .output/chrome-mv3 /mnt/d/项目/Translator-Extension/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.280",
    "@types/node": "^26.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "overrides": {
      "@vitejs/plugin-react": "^4.4.0"
    }
  }
}
